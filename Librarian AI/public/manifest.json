{
    "name": "Librarian AI",
    "description": "An AI-powered academic PDF annotation tool",
    "version": "0.1",
    "manifest_version": 3,
    "permissions": ["activeTab", "storage", "scripting"],
    "action": {
      "default_popup": "popup/index.html",
      "default_icon": "icon.png"
    },
    "background": {
      "service_worker": "background.js"
    },
    
    "content_scripts": [
      { 
        "type": "module",
        "matches": ["*://*/*.pdf", "file:///"],
        "js": ["pdf.worker.mjs", "highlighter.js", "content.js"]
      }
    ]
  }
  